<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DartGui.App.Views.ManualPageView">
  <UserControl.Resources>
    <DataTemplate x:Key="ManualGroupTemplate">
      <Border Classes="manual-group">
        <Grid RowDefinitions="Auto,*" RowSpacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold" />
              <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1"
                IsVisible="{Binding UsesDpad}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RowDefinitions="Auto,Auto,Auto"
                ColumnDefinitions="Auto,Auto,Auto"
                RowSpacing="6"
                ColumnSpacing="6">
            <Button Grid.Row="0"
                    Grid.Column="1"
                    Width="54"
                    Height="54"
                    Tag="{Binding UpButton}"
                    Classes="manual-button dpad"
                    Classes.active="{Binding UpButton.IsActive}"
                    PointerPressed="ManualButtonOnPointerPressed"
                    PointerReleased="ManualButtonOnPointerReleased"
                    PointerCaptureLost="ManualButtonOnPointerReleased"
                    LostFocus="ManualButtonOnPointerReleased"
                    Content="{Binding UpButton.DisplayName}" />
            <Button Grid.Row="1"
                    Grid.Column="0"
                    Width="54"
                    Height="54"
                    Tag="{Binding LeftButton}"
                    Classes="manual-button dpad"
                    Classes.active="{Binding LeftButton.IsActive}"
                    PointerPressed="ManualButtonOnPointerPressed"
                    PointerReleased="ManualButtonOnPointerReleased"
                    PointerCaptureLost="ManualButtonOnPointerReleased"
                    LostFocus="ManualButtonOnPointerReleased"
                    Content="{Binding LeftButton.DisplayName}" />
            <Button Grid.Row="1"
                    Grid.Column="2"
                    Width="54"
                    Height="54"
                    Tag="{Binding RightButton}"
                    Classes="manual-button dpad"
                    Classes.active="{Binding RightButton.IsActive}"
                    PointerPressed="ManualButtonOnPointerPressed"
                    PointerReleased="ManualButtonOnPointerReleased"
                    PointerCaptureLost="ManualButtonOnPointerReleased"
                    LostFocus="ManualButtonOnPointerReleased"
                    Content="{Binding RightButton.DisplayName}" />
            <Button Grid.Row="2"
                    Grid.Column="1"
                    Width="54"
                    Height="54"
                    Tag="{Binding DownButton}"
                    Classes="manual-button dpad"
                    Classes.active="{Binding DownButton.IsActive}"
                    PointerPressed="ManualButtonOnPointerPressed"
                    PointerReleased="ManualButtonOnPointerReleased"
                    PointerCaptureLost="ManualButtonOnPointerReleased"
                    LostFocus="ManualButtonOnPointerReleased"
                    Content="{Binding DownButton.DisplayName}" />
          </Grid>

          <ItemsControl Grid.Row="1"
                        IsVisible="{Binding UsesVerticalLayout}"
                        HorizontalAlignment="Center"
                        ItemsSource="{Binding Buttons}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Margin="0,0,0,8"
                        Tag="{Binding}"
                        Classes="manual-button square"
                        Classes.active="{Binding IsActive}"
                        PointerPressed="ManualButtonOnPointerPressed"
                        PointerReleased="ManualButtonOnPointerReleased"
                        PointerCaptureLost="ManualButtonOnPointerReleased"
                        LostFocus="ManualButtonOnPointerReleased">
                  <TextBlock Text="{Binding DisplayName}" HorizontalAlignment="Center" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>
  <Border Classes="section-card page-card">
    <Grid RowDefinitions="Auto,*" RowSpacing="12">
      <ScrollViewer Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="16">
          <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
            <ContentControl Content="{Binding SyncBeltGroup}"
                            ContentTemplate="{StaticResource ManualGroupTemplate}" />
            <ContentControl Grid.Column="1"
                            Content="{Binding TriggerPositionGroup}"
                            ContentTemplate="{StaticResource ManualGroupTemplate}" />
            <ContentControl Grid.Column="2"
                            Content="{Binding LiftGroup}"
                            ContentTemplate="{StaticResource ManualGroupTemplate}" />
          </Grid>

          <ContentControl Grid.Row="1"
                          MinHeight="240"
                          Content="{Binding AngleGroup}"
                          ContentTemplate="{StaticResource ManualGroupTemplate}" />
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
