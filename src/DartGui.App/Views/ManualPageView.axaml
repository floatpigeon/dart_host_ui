<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DartGui.App.Views.ManualPageView">
  <Border Classes="section-card page-card">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
      <StackPanel Spacing="2">
        <TextBlock Text="手动控制" Classes="section-title" />
        <TextBlock Text="{Binding HintText}"
                   Classes="section-subtitle"
                   TextWrapping="Wrap" />
      </StackPanel>

      <ItemsControl Grid.Row="1" ItemsSource="{Binding Groups}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="2" Rows="2" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,6,6" Classes="manual-group">
              <Grid RowDefinitions="Auto,*" RowSpacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                  </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      IsVisible="{Binding UsesDpad}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="6">
                  <Button Grid.Row="0"
                          Grid.Column="1"
                          Width="54"
                          Height="54"
                          Tag="{Binding UpButton}"
                          Classes="manual-button dpad"
                          Classes.active="{Binding UpButton.IsActive}"
                          PointerPressed="ManualButtonOnPointerPressed"
                          PointerReleased="ManualButtonOnPointerReleased"
                          PointerCaptureLost="ManualButtonOnPointerReleased"
                          LostFocus="ManualButtonOnPointerReleased"
                          Content="{Binding UpButton.DisplayName}" />
                  <Button Grid.Row="1"
                          Grid.Column="0"
                          Width="54"
                          Height="54"
                          Tag="{Binding LeftButton}"
                          Classes="manual-button dpad"
                          Classes.active="{Binding LeftButton.IsActive}"
                          PointerPressed="ManualButtonOnPointerPressed"
                          PointerReleased="ManualButtonOnPointerReleased"
                          PointerCaptureLost="ManualButtonOnPointerReleased"
                          LostFocus="ManualButtonOnPointerReleased"
                          Content="{Binding LeftButton.DisplayName}" />
                  <Border Grid.Row="1"
                          Grid.Column="1"
                          Width="40"
                          Height="40"
                          Classes="dpad-center" />
                  <Button Grid.Row="1"
                          Grid.Column="2"
                          Width="54"
                          Height="54"
                          Tag="{Binding RightButton}"
                          Classes="manual-button dpad"
                          Classes.active="{Binding RightButton.IsActive}"
                          PointerPressed="ManualButtonOnPointerPressed"
                          PointerReleased="ManualButtonOnPointerReleased"
                          PointerCaptureLost="ManualButtonOnPointerReleased"
                          LostFocus="ManualButtonOnPointerReleased"
                          Content="{Binding RightButton.DisplayName}" />
                  <Button Grid.Row="2"
                          Grid.Column="1"
                          Width="54"
                          Height="54"
                          Tag="{Binding DownButton}"
                          Classes="manual-button dpad"
                          Classes.active="{Binding DownButton.IsActive}"
                          PointerPressed="ManualButtonOnPointerPressed"
                          PointerReleased="ManualButtonOnPointerReleased"
                          PointerCaptureLost="ManualButtonOnPointerReleased"
                          LostFocus="ManualButtonOnPointerReleased"
                          Content="{Binding DownButton.DisplayName}" />
                </Grid>

                <ItemsControl Grid.Row="1"
                              IsVisible="{Binding UsesVerticalLayout}"
                              ItemsSource="{Binding Buttons}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Margin="0,0,0,6"
                              Tag="{Binding}"
                              Classes="manual-button tall"
                              Classes.active="{Binding IsActive}"
                              PointerPressed="ManualButtonOnPointerPressed"
                              PointerReleased="ManualButtonOnPointerReleased"
                              PointerCaptureLost="ManualButtonOnPointerReleased"
                              LostFocus="ManualButtonOnPointerReleased">
                        <TextBlock Text="{Binding DisplayName}" HorizontalAlignment="Center" />
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Grid.Row="2" Classes="note-card">
        <StackPanel Spacing="4">
          <TextBlock Text="操作边界" FontSize="12" FontWeight="SemiBold" />
          <TextBlock Text="angle 使用十字键位；其余机构使用纵向键位；按住高亮、松开恢复。"
                     FontSize="10"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>
