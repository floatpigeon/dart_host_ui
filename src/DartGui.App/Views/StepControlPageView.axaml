<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DartGui.App.Views.StepControlPageView">
  <Border Classes="section-card page-card">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding HintTitle}" Classes="section-title" />
        <TextBlock Text="沿用任务控制区的视觉结构，当前只保留单步版式预览。"
                   Classes="section-subtitle"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Border Grid.Row="1" Classes="feedback-banner">
        <StackPanel Spacing="2">
          <TextBlock Text="{Binding HintTitle}" FontSize="12" FontWeight="SemiBold" />
          <TextBlock Text="{Binding HintMessage}"
                     FontSize="10"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <ItemsControl Grid.Row="2" ItemsSource="{Binding Commands}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="2" Rows="3" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Margin="0,0,6,6"
                    Classes="command-button"
                    Classes.pending="{Binding IsPending}"
                    Classes.active="{Binding IsActive}"
                    Command="{Binding SendCommandCommand}">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold" />
                <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
  </Border>
</UserControl>
