<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DartGui.App.Views.CameraPageView">
  <Border Classes="section-card page-card">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
      <StackPanel Spacing="2">
        <TextBlock Text="相机画面" Classes="section-title" />
        <TextBlock Text="双路画面保留为本地比例占位，用于校准版式。"
                   Classes="section-subtitle"
                   TextWrapping="Wrap" />
      </StackPanel>

      <ItemsControl Grid.Row="1" ItemsSource="{Binding Cameras}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="2" Rows="1" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,8,0"
                    Classes="camera-card"
                    Classes.offline="{Binding IsOffline}">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" />
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                  <TextBlock Text="{Binding Resolution}"
                             FontSize="10"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding StatusText}"
                             FontSize="10"
                             FontWeight="Bold" />
                </Grid>

                <Viewbox Grid.Row="2"
                         Stretch="Uniform"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch">
                  <Border Width="288"
                          Height="216"
                          CornerRadius="12"
                          Background="#EAE2D2"
                          BorderBrush="{DynamicResource BorderBrush}"
                          BorderThickness="1"
                          Padding="12">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                      <TextBlock Text="1440 x 1080"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextMutedBrush}" />
                      <TextBlock Text="4:3 画面占位"
                                 FontSize="15"
                                 FontWeight="SemiBold" />
                      <TextBlock Text="{Binding PlaceholderText}"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 TextAlignment="Center"
                                 TextWrapping="Wrap"
                                 MaxWidth="180" />
                    </StackPanel>
                  </Border>
                </Viewbox>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Grid.Row="2" Classes="note-card">
        <StackPanel Spacing="4">
          <TextBlock Text="当前范围" FontSize="12" FontWeight="SemiBold" />
          <TextBlock Text="当前仅显示本地占位和静态元数据。"
                     FontSize="10"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>
